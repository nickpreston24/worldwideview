{
  "name": "worldwideview",
  "version": "2.50.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "test-worktree": "node scripts/test-worktree.mjs",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('.next',{recursive:true,force:true})\"",
    "dev": "node scripts/dev.mjs",
    "dev:all": "concurrently -n \"dev,backends\" -c \"magenta,blue\" \"pnpm dev\" \"pnpm dev:backends\"",
    "dev:backends": "docker compose --profile engine up wwv-data-engine wwv-redis",
    "dev:plugins": "node scripts/watch-local-plugins.mjs",
    "predev": "node scripts/boot-db.mjs && npx dotenv-cli -c -- node scripts/safe-db-push.mjs && npx prisma generate && node scripts/copy-cesium.mjs && node scripts/sync-local-plugins.mjs",
    "copy-cesium": "node scripts/copy-cesium.mjs",
    "prebuild": "node scripts/check-build-env.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:mutate": "stryker run",
    "lint": "eslint .",
    "db:reset": "npx prisma migrate reset --force",
    "db:prune": "node scripts/db-prune.mjs",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@auth/supabase-adapter": "^1.11.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@sentry/nextjs": "^10.57.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.1",
    "@types/pg": "^8.20.0",
    "@worldwideview/wwv-lib-aviation": "workspace:*",
    "@worldwideview/wwv-lib-incidents": "workspace:*",
    "@worldwideview/wwv-plugin-sdk": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cesium": "^1.142.0",
    "cheerio": "^1.2.0",
    "hls.js": "^1.6.16",
    "insecam-api": "^0.0.3",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-auth": "5.0.0-beta.31",
    "openid-client": "^6.8.4",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-player": "^3.4.0",
    "resium": "1.22.0",
    "satellite.js": "^7.0.1",
    "stripe": "^22.2.0",
    "tslib": "^2.8.1",
    "undici": "^8.4.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/cesium": "^1.70.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "concurrently": "^10.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "jsdom": "^28.1.0",
    "rollup-plugin-external-globals": "^0.13.0",
    "supabase": "^2.106.0",
    "tree-kill": "^1.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@spz-loader/core": "0.3.0",
      "form-data@<2.5.4": "^2.5.5",
      "form-data@>=3.0.0 <3.0.4": "^3.0.4",
      "form-data@>=4.0.0 <4.0.4": "^4.0.5",
      "fast-uri@<3.1.2": "^3.1.2",
      "hono@<4.12.21": "^4.12.21",
      "qs@<6.15.2": "^6.15.2",
      "uuid@<11.1.1": "^11.1.1",
      "vitest@<4.1.0": "^4.1.8",
      "esbuild": ">=0.28.1"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@sentry/cli",
      "prisma",
      "protobufjs",
      "sharp",
      "esbuild",
      "better-sqlite3"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
